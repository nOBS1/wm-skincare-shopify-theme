{%- comment -%}
  Product page — GEO/SEO optimized.

  All rich content is metafield-driven (namespace: custom) and hidden gracefully
  when empty, so the page never renders empty wrappers. JSON-LD below stays valid
  JSON in every branch. See GEO-SETUP.md for the metafield definitions + ready-to-paste
  sample values.
{%- endcomment -%}

{%- assign current_variant = product.selected_or_first_available_variant -%}

{%- comment -%} Resolve consumer brand vs. manufacturer (legal entity / vendor).
  vendor on this store = "Lanyuan Elimei Biotech" (the maker); the consumer brand
  "Weiman Poetics" lives in the title ("Weiman Poetics : ..."). Override anytime
  with the custom.brand_name metafield. {%- endcomment -%}
{%- assign product_brand = product.metafields.custom.brand_name -%}
{%- if product_brand == blank and product.title contains ':' -%}
  {%- assign product_brand = product.title | split: ':' | first | strip -%}
{%- endif -%}
{%- if product_brand == blank -%}
  {%- assign product_brand = product.vendor -%}
{%- endif -%}

<div class="container product-page">
  {%- include 'breadcrumb' -%}

  <div class="product-single">
    <div class="product-gallery">
      {%- for image in product.images -%}
        <div class="product-gallery-item">
          <img src="{{ image | image_url: width: 1200 }}"
               srcset="{{ image | image_url: width: 600 }} 600w,
                       {{ image | image_url: width: 1000 }} 1000w,
                       {{ image | image_url: width: 1500 }} 1500w"
               sizes="(max-width: 768px) 100vw, 50vw"
               alt="{{ image.alt | escape | default: product.title }}"
               width="{{ image.width }}" height="{{ image.height }}"
               {% if forloop.first %}loading="eager" fetchpriority="high"{% else %}loading="lazy"{% endif %}>
        </div>
      {%- endfor -%}
    </div>

    <div class="product-info">
      {%- if product_brand != blank -%}
        <span class="product-brand">{{ product_brand }}</span>
      {%- endif -%}

      <h1 class="product-title">{{ product.title }}</h1>

      <div class="product-price">
        {%- if product.compare_at_price > product.price -%}
          <s class="price-compare">{{ product.compare_at_price | money }}</s>
        {%- endif -%}
        <span class="price-current">{{ current_variant.price | money }}</span>
        {%- unless current_variant.available -%}
          <span class="price-status">Sold out</span>
        {%- endunless -%}
      </div>

      {%- if product.metafields.custom.short_pitch != blank -%}
        <p class="product-pitch">{{ product.metafields.custom.short_pitch }}</p>
      {%- elsif product.description != blank -%}
        <p class="product-pitch">{{ product.description | strip_html | truncate: 180 }}</p>
      {%- endif -%}

      {%- form 'product', product, class: 'product-form' -%}
        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            <div class="product-option">
              <label for="Option-{{ forloop.index }}">{{ option.name }}</label>
              <select name="options[{{ option.name | escape }}]" id="Option-{{ forloop.index }}" class="variant-select" form="product-form-{{ section.id }}">
                {%- for value in option.values -%}
                  <option value="{{ value | escape }}" {% if option.selected_value == value %}selected{% endif %}>{{ value }}</option>
                {%- endfor -%}
              </select>
            </div>
          {%- endfor -%}
        {%- endunless -%}

        <input type="hidden" name="id" value="{{ current_variant.id }}">

        <div class="product-quantity">
          <label for="Quantity">Quantity</label>
          <input type="number" id="Quantity" name="quantity" value="1" min="1" class="quantity-input">
        </div>

        <button type="submit" class="btn-add" {% unless current_variant.available %}disabled{% endunless %}>
          {%- if current_variant.available -%}Add to Cart{%- else -%}Sold Out{%- endif -%}
        </button>

        {%- if settings.enable_payment_button -%}
          {{ form | payment_button }}
        {%- endif -%}

        {%- unless current_variant.available -%}
          {%- if product.metafields.custom.restock_note != blank -%}
            <p class="restock-note">{{ product.metafields.custom.restock_note }}</p>
          {%- endif -%}
        {%- endunless -%}
      {%- endform -%}

      <ul class="product-trust">
        <li>Free worldwide shipping over $50</li>
        <li>30-day satisfaction guarantee</li>
        <li>Cruelty-free &amp; dermatologist-tested</li>
      </ul>
    </div>
  </div>

  {%- comment -%} ===== Key benefits ===== {%- endcomment -%}
  {%- if product.metafields.custom.benefits != blank -%}
    <section class="product-section" id="benefits">
      <h2>Key benefits</h2>
      <div class="rte">{{ product.metafields.custom.benefits }}</div>
    </section>
  {%- endif -%}

  {%- comment -%} ===== AI/GEO-friendly Q&A ===== {%- endcomment -%}
  {%- assign has_qa = false -%}
  {%- if product.metafields.custom.who_is_it_for != blank
      or product.metafields.custom.how_to_use != blank
      or product.metafields.custom.key_ingredients != blank -%}
    {%- assign has_qa = true -%}
  {%- endif -%}
  {%- if has_qa -%}
    <section class="product-qa">
      <div class="qa-grid">
        {%- if product.metafields.custom.who_is_it_for != blank -%}
          <article class="qa-item">
            <h2>Who is it for?</h2>
            <div class="rte">{{ product.metafields.custom.who_is_it_for }}</div>
          </article>
        {%- endif -%}
        {%- if product.metafields.custom.how_to_use != blank -%}
          <article class="qa-item">
            <h2>How to use</h2>
            <div class="rte">{{ product.metafields.custom.how_to_use }}</div>
          </article>
        {%- endif -%}
        {%- if product.metafields.custom.key_ingredients != blank -%}
          <article class="qa-item">
            <h2>Key ingredients</h2>
            <div class="rte">{{ product.metafields.custom.key_ingredients }}</div>
          </article>
        {%- endif -%}
      </div>
    </section>
  {%- endif -%}

  {%- comment -%} ===== Specifications (also feeds JSON-LD additionalProperty) ===== {%- endcomment -%}
  {%- if product.metafields.custom.specs != blank -%}
    <section class="product-section" id="specs">
      <h2>Specifications</h2>
      <table class="spec-table">
        <tbody>
          {%- for row in product.metafields.custom.specs.value -%}
            {%- if row.value != blank -%}
              <tr>
                <th scope="row">{{ row.label }}</th>
                <td>{{ row.value }}</td>
              </tr>
            {%- endif -%}
          {%- endfor -%}
        </tbody>
      </table>
    </section>
  {%- endif -%}

  {%- comment -%} ===== Full ingredients / INCI ===== {%- endcomment -%}
  {%- if product.metafields.custom.inci != blank -%}
    <section class="product-section" id="ingredients">
      <h2>Full ingredients (INCI)</h2>
      <div class="rte inci-list">{{ product.metafields.custom.inci }}</div>
    </section>
  {%- endif -%}

  {%- comment -%} ===== Precautions / who should avoid ===== {%- endcomment -%}
  {%- if product.metafields.custom.precautions != blank -%}
    <section class="product-section" id="precautions">
      <h2>Precautions &amp; who should avoid</h2>
      <div class="rte">{{ product.metafields.custom.precautions }}</div>
    </section>
  {%- endif -%}

  {%- comment -%} ===== Brand & maker (entity clarity for GEO) ===== {%- endcomment -%}
  {%- assign show_brand_block = false -%}
  {%- if product.metafields.custom.brand_story != blank -%}{%- assign show_brand_block = true -%}{%- endif -%}
  {%- if product.vendor != blank and product.vendor != product_brand -%}{%- assign show_brand_block = true -%}{%- endif -%}
  {%- if show_brand_block -%}
    <section class="product-section" id="brand">
      <h2>Brand &amp; maker</h2>
      {%- if product.vendor != blank and product.vendor != product_brand -%}
        <p class="brand-entity"><strong>{{ product_brand }}</strong> is a skincare brand manufactured by <strong>{{ product.vendor }}</strong>.</p>
      {%- endif -%}
      {%- if product.metafields.custom.brand_story != blank -%}
        <div class="rte">{{ product.metafields.custom.brand_story }}</div>
      {%- endif -%}
    </section>
  {%- endif -%}

  {%- comment -%} ===== FAQ ===== {%- endcomment -%}
  {%- if product.metafields.custom.faqs != blank -%}
    <section class="product-faq" id="faq">
      <h2>Frequently asked questions</h2>
      <div class="faq-list">
        {%- for faq in product.metafields.custom.faqs.value -%}
          {%- if faq.question != blank -%}
            <details class="faq-item">
              <summary>{{ faq.question }}</summary>
              <div class="faq-answer rte">{{ faq.answer }}</div>
            </details>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </section>
  {%- endif -%}

  {%- comment -%} ===== About (legacy description; h1 -> h2 to avoid a duplicate page H1) ===== {%- endcomment -%}
  {%- if product.description != blank -%}
    <section class="product-section product-full-description" id="about">
      <h2>About this product</h2>
      <div class="rte">{{ product.description | replace: '<h1', '<h2' | replace: '</h1>', '</h2>' }}</div>
    </section>
  {%- endif -%}
</div>

{%- comment -%} ============ JSON-LD: Product (entity graph) ============ {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org/",
  "@type": "Product",
  "@id": "{{ shop.url }}{{ product.url }}#product",
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | truncate: 5000 | json }},
  "url": "{{ shop.url }}{{ product.url }}"
  {%- if product.type != blank -%}
  ,"category": {{ product.type | json }}
  {%- endif -%}
  {%- if current_variant.sku != blank -%}
  ,"sku": {{ current_variant.sku | json }},"mpn": {{ current_variant.sku | json }}
  {%- endif -%}
  {%- if product.images.size > 0 -%}
  ,"image": [
    {%- for image in product.images limit: 5 -%}
      {%- capture img_src -%}{{ image | image_url: width: 1200 }}{%- endcapture -%}
      {%- if img_src contains 'http' -%}{{ img_src | json }}{%- else -%}{{ img_src | prepend: 'https:' | json }}{%- endif -%}
      {%- unless forloop.last %},{% endunless -%}
    {%- endfor -%}
  ]
  {%- endif -%}
  ,"brand": { "@type": "Brand", "name": {{ product_brand | json }} }
  {%- if product.vendor != blank and product.vendor != product_brand -%}
  ,"manufacturer": { "@type": "Organization", "name": {{ product.vendor | json }} }
  {%- endif -%}
  {%- if product.metafields.custom.specs != blank -%}
  ,"additionalProperty": [
    {%- for row in product.metafields.custom.specs.value -%}
      {%- if row.value != blank -%}
      { "@type": "PropertyValue", "name": {{ row.label | json }}, "value": {{ row.value | json }} }
      {%- unless forloop.last %},{% endunless -%}
      {%- endif -%}
    {%- endfor -%}
  ]
  {%- endif -%}
  ,"offers": {
    "@type": "Offer",
    "url": "{{ shop.url }}{{ product.url }}",
    "priceCurrency": {{ cart.currency.iso_code | json }},
    "price": {{ current_variant.price | money_without_currency | remove: ',' | json }},
    "priceValidUntil": "{{ 'now' | date: '%Y' | plus: 1 }}-12-31",
    "availability": "{% if current_variant.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
    "itemCondition": "https://schema.org/NewCondition",
    "seller": { "@type": "Organization", "name": {{ shop.name | json }} }
  }
  {%- if product.metafields.reviews.rating_count and product.metafields.reviews.rating_count.value > 0 -%}
  ,"aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": {{ product.metafields.reviews.rating.value | json }},
    "reviewCount": {{ product.metafields.reviews.rating_count.value | json }}
  }
  {%- endif -%}
}
</script>

{%- comment -%} ============ JSON-LD: FAQPage (GEO-critical) ============ {%- endcomment -%}
{%- if product.metafields.custom.faqs != blank -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- assign faqs = product.metafields.custom.faqs.value -%}
    {%- for faq in faqs -%}
      {%- if faq.question != blank -%}
      {
        "@type": "Question",
        "name": {{ faq.question | json }},
        "acceptedAnswer": {
          "@type": "Answer",
          "text": {{ faq.answer | strip_html | json }}
        }
      }
      {%- unless forloop.last %},{% endunless -%}
      {%- endif -%}
    {%- endfor -%}
  ]
}
</script>
{%- endif -%}

{%- comment -%} ============ JSON-LD: Breadcrumb ============ {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "{{ shop.url }}" }
    {%- if collection -%}
    ,{ "@type": "ListItem", "position": 2, "name": {{ collection.title | json }}, "item": "{{ shop.url }}{{ collection.url }}" }
    ,{ "@type": "ListItem", "position": 3, "name": {{ product.title | json }}, "item": "{{ shop.url }}{{ product.url }}" }
    {%- else -%}
    ,{ "@type": "ListItem", "position": 2, "name": {{ product.title | json }}, "item": "{{ shop.url }}{{ product.url }}" }
    {%- endif -%}
  ]
}
</script>

{% schema %}
{
  "name": "Product page",
  "settings": []
}
{% endschema %}
