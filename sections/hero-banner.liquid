{%- assign image = section.settings.image -%}
{%- assign opacity = section.settings.overlay_opacity | default: 0 -%}
<section class="hero {% if image == blank %}hero--placeholder{% endif %}">
  {%- if image != blank -%}
    <img
      class="hero-image"
      src="{{ image | image_url: width: 2400 }}"
      srcset="{{ image | image_url: width: 600 }} 600w,
              {{ image | image_url: width: 1000 }} 1000w,
              {{ image | image_url: width: 1500 }} 1500w,
              {{ image | image_url: width: 2000 }} 2000w,
              {{ image | image_url: width: 2400 }} 2400w,
              {{ image | image_url: width: 3000 }} 3000w"
      sizes="100vw"
      alt="{{ image.alt | default: shop.name | escape }}"
      width="{{ image.width }}"
      height="{{ image.height }}"
      loading="eager"
      fetchpriority="high">
    {%- if opacity > 0 -%}
      <div class="hero-overlay" style="background: rgba(0,0,0,{{ opacity | divided_by: 100.0 }})"></div>
    {%- endif -%}
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Hero banner",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Hero image" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 60, "step": 5, "unit": "%", "default": 0 }
  ],
  "presets": [{ "name": "Hero banner" }]
}
{% endschema %}
