{%- assign image = section.settings.image -%}
<section class="hero" {% if image != blank %}style="background-image:url({{ image | image_url: width: 1920 }})"{% else %}style="background:#0d0d0d"{% endif %}>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    {%- if section.settings.heading != blank -%}
      <h1>{{ section.settings.heading }}</h1>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p>{{ section.settings.subheading }}</p>
    {%- endif -%}
    {%- if section.settings.button_text != blank -%}
      <a href="{{ section.settings.button_link }}" class="btn btn-outline">{{ section.settings.button_text }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Hero banner",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Art of Ageless Skin" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Exosome-powered luxury skincare" },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "Shop Now" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [{ "name": "Hero banner" }]
}
{% endschema %}
