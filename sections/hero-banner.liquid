{%- assign image = section.settings.image -%}
<section class="hero hero-image-only" {% if image != blank %}style="background-image:url({{ image | image_url: width: 1920 }})"{% else %}style="background: linear-gradient(135deg, #1a1a1a 0%, #2d2422 50%, #1a1a1a 100%)"{% endif %}>
  {%- if section.settings.link != blank -%}
    <a href="{{ section.settings.link }}" class="hero-link" aria-label="{{ shop.name }}"></a>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Hero banner",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "url", "id": "link", "label": "Image link (optional)" }
  ],
  "presets": [{ "name": "Hero banner" }]
}
{% endschema %}
